#!/bin/sh

set -e -x

# Kernel Source
KERNEL_SOURCE="https://github.com/StimLuks87/android_kernel_realme_salaa"
KERNEL_BRANCH="16QPR2"
KERNEL_DEFCONFIG="salaa_defconfig"

# Ссылка на оптимизированный Proton Clang (LLVM 19) с GitLab
CLANG_GITLAB="https://gitlab.com/LeCmnGend/clang"
CLANG_BRANCH="clang-19"

# Настройка команды make для полного LLVM окружения
make_fun() {
	make O=out ARCH=arm64 \
		CC=clang \
		HOSTCC=clang \
		DTC=dtc \
		LLVM=1 \
		LLVM_IAS=1 \
		CROSS_COMPILE=aarch64-linux-gnu- \
		CROSS_COMPILE_COMPAT=arm-linux-gnueabi- "$@"
}

# Work Path
WORK="${HOME}/work"

# Kernel Folder Name
KERNEL="myKernel"

# Kernel Source Path
KERNEL_SRC="${WORK}/${KERNEL}"

# Prepare Directory
mkdir -p "${WORK}"
cd "${WORK}" || exit 1

# Быстрое клонирование Clang из GitLab
[ ! -d clang ] && git clone --depth=1 "${CLANG_GITLAB}" -b "${CLANG_BRANCH}" ./clang

# Клонирование исходников ядра
[ ! -d "${KERNEL}" ] && git clone --depth=1 "${KERNEL_SOURCE}" -b "${KERNEL_BRANCH}" "${KERNEL}"

# В PATH прописывается только бинарник нового Clang
PATH="${WORK}/clang/bin:/bin:/usr/bin"

# Переходим в корень исходников ядра
cd "${KERNEL_SRC}" || exit 1

# Запуск компиляции ядра под Realme Salaa
make_fun "${KERNEL_DEFCONFIG}"
make_fun -j"$(nproc --all)" 2>&1 | tee build.log


# ====================================================================
# ИНТЕГРАЦИЯ С ВАШИМ ANYKERNEL3 И СБОРКА ИТОГОВОГО ZIP
# ====================================================================

# Генерируем текущую дату для имени файла (замена пустой переменной TANGGAL)
DATE_NOW=$(date +%Y%m%d-%H%m)

# Проверяем, скомпилировался ли файл ядра Image.gz-dtb
if [ -f "${KERNEL_SRC}/out/arch/arm64/boot/Image.gz-dtb" ]; then
    echo "Ядро успешно собрано! Начинаем упаковку в AnyKernel..."
    
    # Клонируем ваш собственный настроенный репозиторий AnyKernel3
    git clone --depth=1 https://github.com/Luks-organization/AnyKernel3.git "${WORK}/AnyKernel"
    
    # Копируем свежее ядро из папки сборки в ваш AnyKernel
    cp "${KERNEL_SRC}/out/arch/arm64/boot/Image.gz-dtb" "${WORK}/AnyKernel/"
    
    # Переходим в папку упаковщика
    cd "${WORK}/AnyKernel" || exit 1
    
    # Создаем готовый архив прошивки Bolt-ZAP
    zip -r9 "${WORK}/Bolt-ZAP-salaa-${DATE_NOW}.zip" ./* -x .git* README.md
    
    echo "Сборка AnyKernel завершена! Готовый ZIP лежит в корне папки ${WORK}"
else
    echo "Ошибка: Файл Image.gz-dtb не найден. Компиляция завершилась с ошибкой."
    exit 1
fi
